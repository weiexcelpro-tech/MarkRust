{
  "name": "markrust",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MarkText rewritten with Tauri 2 + Rust main process, reusing Vue3 renderer and muya engine",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .ts,.vue --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:contract": "vitest run tests/contract/",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "node tests/e2e/run-edge.cjs",
    "test:all": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@floating-ui/dom": "^1.7.6",
    "@intlify/core-base": "^11.4.6",
    "@popperjs/core": "^2.11.8",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "arg": "^5.0.2",
    "axios": "^1.18.0",
    "codemirror": "^5.65.21",
    "command-exists": "^1.2.9",
    "dayjs": "^1.11.21",
    "deep-equal": "^2.2.3",
    "dom-autoscroller": "^2.3.4",
    "dompurify": "^3.4.11",
    "dragula": "^3.7.3",
    "element-plus": "^2.14.2",
    "element-resize-detector": "^1.2.4",
    "execall": "^3.0.0",
    "fast-diff": "^1.3.0",
    "flowchart.js": "^1.18.0",
    "font-list": "^2.1.0",
    "fuse.js": "^7.4.2",
    "fuzzaldrin": "^2.1.0",
    "github-markdown-css": "^5.9.0",
    "html-tags": "^5.1.0",
    "iso-639-1": "^3.1.5",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "katex": "^0.17.0",
    "lodash": "^4.18.1",
    "marked": "^18.0.5",
