    "plantuml-encoder": "^1.4.0",
    "plist": "^5.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "snabbdom": "^3.6.4",
    "snabbdom-to-html": "^7.1.0",
    "snapsvg-cjs": "^0.0.6",
    "turndown": "^7.2.4",
    "underscore": "^1.13.8",
    "vega": "^6.2.0",
