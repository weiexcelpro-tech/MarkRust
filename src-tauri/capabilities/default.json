{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for editor/settings windows. Grants core + shell + dialog + window + webview + menu permissions needed by Phase 1 (fs IO + watching + ripgrep) and Phase 2 (window mgmt + menu routing + native dialogs).",
  "windows": ["main", "editor-*", "settings"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-set-always-on-top",
    "core:window:allow-is-always-on-top",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-center",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "core:menu:default",
    "shell:allow-open",
    "shell:default",
    "dialog:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
